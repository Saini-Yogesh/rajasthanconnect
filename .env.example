# ─── Frontend (Vite) — copy to .env in project root ───────────────────────────
# Required for production builds on Vercel (set in Vercel → Settings → Environment Variables)

# Live backend API URL — no trailing slash
# Example: https://api.rajasthanconnect.in  or  https://your-backend.railway.app
VITE_API_URL=http://localhost:5000

# Optional: Google Analytics 4 Measurement ID (from analytics.google.com)
# Example: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Site URL used for SEO canonical tags (defaults to https://www.rajasthanconnect.in)
VITE_SITE_URL=https://www.rajasthanconnect.in
