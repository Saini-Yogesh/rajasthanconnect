# Backend — copy to backend/.env
# NEVER commit backend/.env to git

NODE_ENV=development
PORT=5000

# PostgreSQL connection string (required for live data)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Groq AI — required for live AI Planner & Ask AI (falls back to local responses if unset)
# Use GROQ_API_KEY LIKE GROQ_API_KEY_1 … GROQ_API_KEY_10 for rotation
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# Image Finder script (scripts/image_finder/) — stock photo search
# Use PEXELS_API_KEY LIKE PEXELS_API_KEY_1 … PEXELS_API_KEY_10 for rotation
PEXELS_API_KEY_1=
PEXELS_API_KEY_2=
PEXELS_API_KEY_3=

# EmailJS for business directory listing notifications (optional)
EMAILJS_LISTING_SERVICE_ID=
EMAILJS_LISTING_TEMPLATE_ID=
EMAILJS_LISTING_PUBLIC_KEY=
EMAILJS_LISTING_PRIVATE_KEY=

# EmailJS for user feedback notifications (optional)
EMAILJS_FEEDBACK_SERVICE_ID=
EMAILJS_FEEDBACK_TEMPLATE_ID=
EMAILJS_FEEDBACK_PUBLIC_KEY=
EMAILJS_FEEDBACK_PRIVATE_KEY=

# Redis response cache (optional)
ENABLE_REDIS=false
REDIS_URL=

# Comma-separated frontend origins allowed by CORS (production)
# Example: https://rajasthanconnect.in,https://www.rajasthanconnect.in
FRONTEND_URLS=http://localhost:5173
